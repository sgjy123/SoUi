{
  "name": "@soui/ui",
  "version": "1.0.0",
  "description": "A modern React component library based on Vite and TypeScript",
  "type": "module",
  "main": "dist/soui.umd.js",
  "module": "dist/soui.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/soui.es.js",
      "require": "./dist/soui.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./components/*": "./src/components/*/index.tsx"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "clean": "rimraf dist lib es",
    "docs:dev": "npm run build && vitepress dev src/docs",
    "docs:build": "vitepress build src/docs",
    "docs:preview": "vitepress preview src/docs"
  },
  "keywords": [
    "react",
    "component",
    "components",
    "ui",
    "library",
    "typescript",
    "vite"
  ],
  "author": "SoUi Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/souI/ui"
  },
  "bugs": {
    "url": "https://github.com/souI/ui/issues"
  },
  "homepage": "https://github.com/souI/ui#readme",
  "peerDependencies": {
    "react": ">=18.0.0 <20",
    "react-dom": ">=18.0.0 <20"
  },
  "dependencies": {
    "@icon-park/react": "^1.4.2",
    "classnames": "^2.5.1",
    "prism-react-renderer": "^2.4.1",
    "react-live": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "crypto-browserify": "^3.12.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "less": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.3.3",
    "vite": "^4.5.0",
    "vitepress": "^1.0.0-rc.45"
  },
  "volta": {
    "node": "18.20.8"
  }
}
